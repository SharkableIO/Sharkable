<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Description>🌈Powerful tools for dotnet aot and more</Description>
    <AssemblyVersion>0.5.5</AssemblyVersion>
    <Version>0.5.5</Version>
    <PackageIcon>sharkable.jpg</PackageIcon>
    <PackageReleaseNotes>SHARK-SEC-003: replace Thread.Sleep with await Task.Delay in graceful shutdown drain; true fire-and-forget so ApplicationStopping returns immediately. SHARK-SEC-004: make SagaExecutor.LockTtl configurable; add LockRenewalInterval with periodic lock extension (cross-repo Cache.Redis); ISagaStore.RenewLockAsync converted to default interface method so existing implementations keep compiling. SHARK-SEC-005 (cross-repo Cache.Redis): replace unconditional KeyDelete with check-and-delete Lua in RedisSagaStore / RedisCronJobStore; add CronScheduler.CronLockTtl + ICronJobStore.RenewJobLockAsync. Idempotency hardening: add MaxFingerprintBodySize (default 64 KiB); chunked-transfer requests now hash incrementally with -1 sentinel; setter rejects &lt;= 0. SHARK-SEC-006 (AutoCrud.SqlSugar, BREAKING): add [CrudAllow] field allowlist; endpoints with zero [CrudAllow] properties throw InvalidOperationException at startup. SHARK-SEC-006 follow-ups (BREAKING): exclude SafeSoftDeleteField from [CrudAllow] allow-list even when explicitly marked; AutoCrud POST and PUT now return the persisted row re-read from DB.</PackageReleaseNotes>
    <PackageProjectUrl>https://sharkableio.github.io/</PackageProjectUrl>
    <RepositoryUrl>https://github.com/SharkableIO/Sharkable.git</RepositoryUrl>
    <PackageTags>dotnet,minimalapi,toolkit,framework</PackageTags>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <Copyright>CharleyPeng</Copyright>
    <Authors>CharleyPeng</Authors>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FluentValidation" Version="12.1.1" />
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.7" />
    <PackageReference Include="Microsoft.OpenApi" Version="2.7.5" />
    <PackageReference Include="Scalar.AspNetCore" Version="2.16.8" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="10.0.7" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="SharkEndpoint\Enums\" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Sharkable.Tests" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Sharkable.Analyzers\Sharkable.Analyzers.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="" />
    <None Include="sharkable.jpg" Pack="true" PackagePath="" />
  </ItemGroup>

  <ItemGroup>
    <None Include="analyzers\dotnet\cs\Sharkable.Analyzers.dll" Pack="true" PackagePath="analyzers/dotnet/cs" />
  </ItemGroup>

</Project>
