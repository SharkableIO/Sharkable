<?xml version="1.0" encoding="utf-8"?>
<package >
  <metadata>
    <id>Sharkable</id>
    <version>0.5.5</version>
    <title>Sharkable</title>
    <authors>charleypeng</authors>
    <readme>docs\README.md</readme>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <icon>sharkable.jpg</icon>
    <projectUrl>https://sharkableio.github.io/</projectUrl>
    <description>a dotnet minimal api framework collection aimed to support aot</description>
    <releaseNotes>SHARK-SEC-003 (Thread.Sleep to await Task.Delay in graceful shutdown, true fire-and-forget). SHARK-SEC-004 (configurable SagaExecutor.LockTtl + LockRenewalInterval; ISagaStore.RenewLockAsync as DIM). SHARK-SEC-005 (cross-repo Cache.Redis: check-and-delete Lua in RedisSagaStore / RedisCronJobStore; CronScheduler.CronLockTtl + ICronJobStore.RenewJobLockAsync). Idempotency hardening (MaxFingerprintBodySize, incremental chunked hashing, setter validation). SHARK-SEC-006 cross-repo AutoCrud.SqlSugar BREAKING: [CrudAllow] field allowlist; SafeSoftDeleteField excluded even when marked; POST/PUT return persisted row. Pin Microsoft.OpenApi to 2.7.5 for NU1903 (CVE-2026-49451).</releaseNotes>
    <copyright>CopyRight 2026 Penglei</copyright>
    <tags>minimalapi aot framework toolkit</tags>
    <dependencies>
      <dependency id="Microsoft.AspNetCore.OpenApi" version="10.0.7" />
      <dependency id="Scalar.AspNetCore" version="2.16.8" />
      <dependency id="FluentValidation" version="12.1.1" />
      <dependency id="Microsoft.OpenApi" version="2.7.5" />
    </dependencies>
  </metadata>
   <files>
    <file src="README.md" target="docs\" />
    <file src="sharkable.jpg" target="\" />
    <file src="bin\$configuration$\net10.0\Sharkable.xml" target="\" />
  </files>
</package>